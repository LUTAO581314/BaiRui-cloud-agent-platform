POSTGRES_PASSWORD=replace-with-random-database-password
BAIRUI_DATABASE_SSL=0
BAIRUI_PLATFORM_ORIGIN=https://agent.example.com
BAIRUI_SESSION_SECRET=replace-with-at-least-32-random-characters
BAIRUI_BOOTSTRAP_ADMIN_EMAIL=admin@example.com
BAIRUI_BOOTSTRAP_ADMIN_PASSWORD=replace-with-a-strong-bootstrap-password
BAIRUI_AGENT_INGEST_TOKEN=replace-with-random-machine-token
BAIRUI_CHANNEL_WORKER_ID=channel-worker-primary
BAIRUI_CHANNEL_WORKER_TOKEN=replace-with-separate-channel-worker-machine-token
BAIRUI_CHANNEL_WORKER_CHANNELS=feishu,wechat,qq
BAIRUI_CHANNEL_INVENTORY_INTERVAL_MS=30000
BAIRUI_CHANNEL_DELIVERY_INTERVAL_MS=1000
BAIRUI_CHANNEL_DELIVERY_BATCH_SIZE=20
BAIRUI_CHANNEL_DELIVERY_LEASE_SECONDS=60
BAIRUI_RUNTIME_URL=http://host.docker.internal:8787
BAIRUI_RUNTIME_SHARED_SECRET=replace-with-runtime-shared-secret
BAIRUI_RUNTIME_ROUTE_HOSTS=host.docker.internal
BAIRUI_PROVIDER_ENCRYPTION_KEY=replace-with-separate-provider-encryption-key
BAIRUI_LICENSE_PRIVATE_KEY=replace-with-ed25519-private-key-pem-using-escaped-newlines
BAIRUI_RETENTION_INTERVAL_MS=21600000
BAIRUI_RESOURCE_STALE_AFTER_MS=120000
BAIRUI_MEMORY_WORKER_INTERVAL_MS=2000
BAIRUI_MEMORY_WORKER_BATCH_SIZE=4
BAIRUI_MEMORY_WORKER_LEASE_SECONDS=90
BAIRUI_MEMORY_WORKER_MAX_ATTEMPTS=8
BAIRUI_MEMORY_WORKER_BASE_RETRY_MS=2000
BAIRUI_MEMORY_WORKER_MAX_RETRY_MS=300000
