BAIRUI_PLATFORM_URL=https://bairui.example.com
BAIRUI_SERVER_ID=replace-with-registered-server-id
BAIRUI_SERVER_AGENT_TOKEN=replace-with-one-time-server-token
BAIRUI_AGENT_INSTANCES_ROOT=/var/lib/bairui/agents
BAIRUI_RUNTIME_ADVERTISE_HOST=host.docker.internal
BAIRUI_RUNTIME_PORT_START=19000
BAIRUI_RUNTIME_PORT_END=19999
BAIRUI_CONTROL_POLL_INTERVAL_MS=5000
BAIRUI_CONTROL_LEASE_LIMIT=5
BAIRUI_CONTROL_LEASE_SECONDS=120
HERMES_IMAGE=replace-with-verified-hermes-image-digest
BAIRUI_RUNTIME_IMAGE=replace-with-verified-runtime-image-digest
