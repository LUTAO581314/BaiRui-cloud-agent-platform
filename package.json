{
  "name": "bairui-cloud-agent-platform",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "engines": {
    "node": ">=24"
  },
  "dependencies": {
    "pg": "^8.16.0",
    "yaml": "^2.8.1"
  },
  "scripts": {
    "test": "node --test \"tests/*.test.mjs\"",
    "verify": "node --test \"tests/*.test.mjs\" && node scripts/check-platform.mjs",
    "deploy:check": "node scripts/check-platform.mjs",
    "db:migrate": "node packages/db/bin/migrate.mjs",
    "db:schema:check": "node scripts/check-postgres-schema.mjs",
    "db:migration:print": "node packages/db/bin/print-migration.mjs",
    "deployment:bundle:print": "node packages/deployment/bin/print-bundle.mjs",
    "delivery:write": "node packages/deployment/bin/write-delivery.mjs",
    "delivery:verify": "node packages/deployment/bin/verify-delivery.mjs",
    "delivery:archive": "node packages/deployment/bin/archive-delivery.mjs",
    "delivery:release": "node packages/deployment/bin/release-delivery.mjs",
    "platform:dev": "node apps/web/server.mjs",
    "server-agent:once": "node server-agent/index.mjs",
    "server-agent:daemon": "node server-agent/daemon.mjs",
    "server-agent:acceptance": "node server-agent/bin/acceptance-check.mjs",
    "license:generate": "node packages/license/bin/generate-license.mjs",
    "operations:backup": "node scripts/operations/backup-postgres.mjs",
    "operations:restore": "node scripts/operations/restore-postgres.mjs",
    "operations:rollback": "node scripts/operations/rollback-compose.mjs"
  }
}
